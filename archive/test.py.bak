if __name__ == "__main__":
    # specify the Image path to be tested
    # Please Ensure that the path is in the format r"D:\path-to-the-image"
    ImagePath = r"E:\GUC files\semester 9\CV\project-mit-kase-1\project_dataset\images\train\113044.jpg"
    ImageName = "8068"
    
    ## Read The Image
    image = cv2.imread(ImagePath)
    image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)
    
    ## Call the method PbLite in PbLite repo
    print("start PbLite Algorithm")
    start = timeit.default_timer()
    PbLite = PbLite.PbLite(str(ImageName), ImagePath)
    print("end PbLite Algorithm")
    
    ## Use encoder Decoder Network to predict the contours
    print("start encoder decoder prediction")
    Contours = ContourDetector.detectContours(str(ImageName), ImagePath)
    print("end encoder decoder prediction")
    
    
    ## Call the method MeanShiftSegmentation that is implemented in the file MySegmentation.py
    print("start Segmentation")
    segmented = MySegmentation.MeanShiftSegmentation(ImagePath)
    print("start FCN Model Segmentation")
    segmented_FCN = FCN.FCN_RESNET101(ImagePath)
    stop = timeit.default_timer()
    print('Time: ', stop - start)
    plt.figure("Results")
    plt.subplot(2, 2, 1), plt.imshow(Contours, cmap='gray')
    plt.title('Using encoderDecoder network'), plt.xticks([]), plt.yticks([])
    plt.subplot(2, 2, 2), plt.imshow(PbLite, cmap='gray')
    plt.title('Using PbLite'), plt.xticks([]), plt.yticks([])
    plt.subplot(2, 2, 3), plt.imshow(segmented, cmap='gray')
    plt.title('MeanShift Segmentation Result'), plt.xticks([]), plt.yticks([])
    plt.subplot(2, 2, 4), plt.imshow(segmented_FCN, cmap='gray')
    plt.title('FCN ResNet101 Segmentation'), plt.xticks([]), plt.yticks([])
    plt.savefig("Results.png", dpi=200)
    plt.show()
    