    Pb_results_path = r'E:\GUC files\semester 9\CV\Contour Detection and image segmentation\Results\PbLiteResults'

    ground_truth_images = np.array([cv2.imread(os.path.join(ground_Truth_path,name),0) for name in testlist], dtype=object)
    encoder_decoder_results = np.array([cv2.imread(os.path.join(encoder_decoder_results_path,name),0) for name in testlist], dtype=object)
    PbLiteResults = np.array([cv2.imread(os.path.join(Pb_results_path,'PbLite_'+str(name[0:-4])+'.png'),0) for name in testlist], dtype=object)
    
    enocderDecoderPSNR = 0
    MaxenocderDecoderPSNR = -1
    MinenocderDecoderPSNR = 100
    
    enocderDecoderSSIM = 0
    MaxenocderDecoderSSIM = -1
    MinenocderDecoderSSIM = 1
    
    PbLitePSNR=0
    MaxPbLitePSNR = -1
    MinPbLitePSNR = 100
    
    PbLiteSSIM=0
    MaxPbLiteSSIM = -1
    MinPbLiteSSIM = 1
    
    for i in range(0,200):
        psnr1 = PSNR(ground_truth_images[i], encoder_decoder_results[i])
        psnr2 = PSNR(ground_truth_images[i], PbLiteResults[i])
        ssim1 = ssim(ground_truth_images[i], encoder_decoder_results[i])
        ssim2 = ssim(ground_truth_images[i], PbLiteResults[i])

        enocderDecoderPSNR+=psnr1
        PbLitePSNR+=psnr2
        enocderDecoderSSIM+=ssim1
        PbLiteSSIM+=ssim2
        
        
        if(psnr1 > MaxenocderDecoderPSNR):
            MaxenocderDecoderPSNR = psnr1
        if(psnr1 < MinenocderDecoderPSNR):
            MinenocderDecoderPSNR = psnr1
            
        if(ssim1 > MaxenocderDecoderSSIM):
            MaxenocderDecoderSSIM = ssim1
        if(ssim1 < MinenocderDecoderSSIM):
            MinenocderDecoderSSIM = ssim1
            
        if(psnr2 > MaxPbLitePSNR):
            MaxPbLitePSNR = psnr2
        if(psnr2 < MinPbLitePSNR):
            MinPbLitePSNR = psnr2
        
        if(ssim2 > MaxPbLiteSSIM):
            MaxPbLiteSSIM = ssim2
        if(ssim2 < MinPbLiteSSIM):
            MinPbLiteSSIM = ssim2
        
        
        
    EnocderDecoderAveragePSNR = enocderDecoderPSNR/200.0
    PbLiteAveragePSNR = PbLitePSNR/200.0
    EnocderDecoderAverageSSIM = enocderDecoderSSIM/200.0
    PbLiteAverageSSIM = PbLiteSSIM/200.0
    
    
    print('For Encoder Decoder Network: ')
    print("Average PSNR : ", EnocderDecoderAveragePSNR)
    print("Maximum PSNR recorded: ",MaxenocderDecoderPSNR)
    print("Minimum PSNR recorded: ",MinenocderDecoderPSNR)
    print()
